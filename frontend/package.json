{
  "name": "omnipub-frontend",
  "private": true,
  "version": "1.4.0",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "vite build",
    "preview": "vite preview",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:e2e": "playwright test",
    "test:e2e:ui": "playwright test --ui",
    "seed-profile": "npx tsx e2e/launch-chromium.ts",
    "check-sessions": "npx tsx e2e/session-health.ts",
    "check-sessions:json": "npx tsx e2e/session-health.ts --json",
    "check-health": "npx tsx e2e/platform-health.ts",
    "check-health:json": "npx tsx e2e/platform-health.ts --json",
    "test:real-world": "playwright test --project=real-world --reporter=list",
    "test:real": "PLAYWRIGHT_TEST_BASE_URL=http://localhost:3000 npx playwright test --project=real-world",
    "setup:test-profile": "bash scripts/setup-test-profile.sh"
  },
  "dependencies": {
    "axios": "^1.15.2",
    "pinia": "^2.3.1",
    "vditor": "^3.10.8",
    "vue": "^3.5.13",
    "vue-router": "^4.5.0"
  },
  "devDependencies": {
    "@pinia/testing": "^0.1.7",
    "@playwright/test": "^1.58.2",
    "@tailwindcss/vite": "^4.0.0",
    "@vitest/coverage-v8": "^3.2.1",
    "@vitejs/plugin-vue": "^5.2.1",
    "@vue/test-utils": "^2.4.6",
    "happy-dom": "^18.0.1",
    "tailwindcss": "^4.0.0",
    "vite": "^6.0.7",
    "vitest": "^3.2.1"
  }
}
